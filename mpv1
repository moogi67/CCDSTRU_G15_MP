#include <stdio.h>
#include <string.h>

typedef int t_arrCoord[2];
typedef char t_szString10[11];

void InitializeSet(t_arrCoord arrSet[], int nSize, int bIsFreeSet)
{
    int i;

    for(i = 0; i < nSize; i++)
    {
        if(bIsFreeSet)
        {
            arrSet[i][0] = i / 3;
            arrSet[i][1] = i % 3;
        }
        else
        {
            arrSet[i][0] = -1;
            arrSet[i][1] = -1;
        }
    }
}

int SearchCoordinateIndex(t_arrCoord arrHaystack[], t_arrCoord arrKey, int nSize)
{
    int iIndex,
        iResult = -1,
        bIsMatch = 0;

    for(iIndex = 0; iIndex < nSize && !bIsMatch; iIndex++)
    {
        if(arrHaystack[iIndex][0] == arrKey[0] &&
           arrHaystack[iIndex][1] == arrKey[1])
        {
            iResult = iIndex;
            bIsMatch = 1;
        }
    }

    return iResult;
}

void ClearCoordinate(t_arrCoord arrPositions[], int iIndex, int *pnTotal)
{
    arrPositions[iIndex][0] = -1;
    arrPositions[iIndex][1] = -1;
    (*pnTotal)--;
}

void AddCoordinate(t_arrCoord arrPositions[], t_arrCoord arrPos, int iIndex, int *pnTotal)
{
    arrPositions[iIndex][0] = arrPos[0];
    arrPositions[iIndex][1] = arrPos[1];
    (*pnTotal)++;
}

void ProcessRemoval(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                    t_arrCoord arrActiveSetS[], t_arrCoord arrTraversedSetT[], t_arrCoord arrFreeSet[],
                    int *pbIsRedTurn, int *pnTotalRed, int *pnTotalBlue,
                    int *pnTotalS, int *pnTotalT, int *pnTotalFree)
{
    int iIndexOwner,
        iIndexFree;
    t_arrCoord arrEmpty = {-1, -1};

    if((*pbIsRedTurn))
    {
        iIndexOwner = SearchCoordinateIndex(arrRedSet, arrTargetPos, 9);
        if(iIndexOwner >= 0)
        {
            ClearCoordinate(arrRedSet, iIndexOwner, pnTotalRed);
            iIndexFree = SearchCoordinateIndex(arrFreeSet, arrEmpty, 9);
            if(iIndexFree >= 0)
                AddCoordinate(arrFreeSet, arrTargetPos, iIndexFree, pnTotalFree);
        }
    }
    else
    {
        iIndexOwner = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);
        if(iIndexOwner >= 0)
        {
            ClearCoordinate(arrBlueSet, iIndexOwner, pnTotalBlue);
            iIndexFree = SearchCoordinateIndex(arrFreeSet, arrEmpty, 9);
            if(iIndexFree >= 0)
                AddCoordinate(arrFreeSet, arrTargetPos, iIndexFree, pnTotalFree);
        }
    }

    iIndexOwner = SearchCoordinateIndex(arrActiveSetS, arrTargetPos, 9);
    if(iIndexOwner >= 0)
        ClearCoordinate(arrActiveSetS, iIndexOwner, pnTotalS);

    iIndexOwner = SearchCoordinateIndex(arrTraversedSetT, arrTargetPos, 9);
    if(iIndexOwner >= 0)
        ClearCoordinate(arrTraversedSetT, iIndexOwner, pnTotalT);
}

void TriggerExpansion(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                      t_arrCoord arrActiveSetS[], t_arrCoord arrTraversedSetT[], t_arrCoord arrFreeSet[],
                      int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                      int *pnTotalS, int *pnTotalT, int *pnTotalFree);

void ExecuteReplacement(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                        t_arrCoord arrActiveSetS[], t_arrCoord arrTraversedSetT[], t_arrCoord arrFreeSet[],
                        int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                        int *pnTotalS, int *pnTotalT, int *pnTotalFree)
{
    int iIndex,
        iEmptyIndex;
    t_arrCoord arrEmpty = {-1, -1};

    *pbIsFound = 0;

    if(arrTargetPos[0] >= 0 && arrTargetPos[0] <= 2 &&
       arrTargetPos[1] >= 0 && arrTargetPos[1] <= 2)
    {
        iIndex = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);
        if((*pbIsRedTurn) && iIndex >= 0)
        {
            ClearCoordinate(arrBlueSet, iIndex, pnTotalBlue);

            iEmptyIndex = SearchCoordinateIndex(arrFreeSet, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrFreeSet, arrTargetPos, iEmptyIndex, pnTotalFree);

            *pbIsFound = 1;
        }

        iIndex = SearchCoordinateIndex(arrRedSet, arrTargetPos, 9);
        if((*pbIsRedTurn) && iIndex >= 0)
        {
            *pbIsFound = 1;
        }
        else if((*pbIsRedTurn) && iIndex < 0)
        {
            iEmptyIndex = SearchCoordinateIndex(arrRedSet, arrEmpty, 9);
            if(iEmptyIndex >= 0)
            {
                AddCoordinate(arrRedSet, arrTargetPos, iEmptyIndex, pnTotalRed);

                iIndex = SearchCoordinateIndex(arrFreeSet, arrTargetPos, 9);
                if(iIndex >= 0)
                    ClearCoordinate(arrFreeSet, iIndex, pnTotalFree);
            }
        }

        if(!(*pbIsRedTurn) && iIndex >= 0)
        {
            ClearCoordinate(arrRedSet, iIndex, pnTotalRed);

            iEmptyIndex = SearchCoordinateIndex(arrFreeSet, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrFreeSet, arrTargetPos, iEmptyIndex, pnTotalFree);

            *pbIsFound = 1;
        }

        iIndex = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);
        if(!(*pbIsRedTurn) && iIndex >= 0)
        {
            *pbIsFound = 1;
        }
        else if(!(*pbIsRedTurn) && iIndex < 0)
        {
            iEmptyIndex = SearchCoordinateIndex(arrBlueSet, arrEmpty, 9);
            if(iEmptyIndex >= 0)
            {
                AddCoordinate(arrBlueSet, arrTargetPos, iEmptyIndex, pnTotalBlue);

                iIndex = SearchCoordinateIndex(arrFreeSet, arrTargetPos, 9);
                if(iIndex >= 0)
                    ClearCoordinate(arrFreeSet, iIndex, pnTotalFree);
            }
        }

        iIndex = SearchCoordinateIndex(arrActiveSetS, arrTargetPos, 9);
        if((*pbIsFound) && iIndex < 0)
        {
            iEmptyIndex = SearchCoordinateIndex(arrActiveSetS, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrActiveSetS, arrTargetPos, iEmptyIndex, pnTotalS);

            *pbIsFound = 0;
        }
        else if((*pbIsFound) && iIndex >= 0)
        {
            iIndex = SearchCoordinateIndex(arrTraversedSetT, arrTargetPos, 9);
            if(iIndex < 0)
            {
                iEmptyIndex = SearchCoordinateIndex(arrTraversedSetT, arrEmpty, 9);
                if(iEmptyIndex >= 0)
                    AddCoordinate(arrTraversedSetT, arrTargetPos, iEmptyIndex, pnTotalT);

                TriggerExpansion(arrTargetPos, arrRedSet, arrBlueSet,
                                 arrActiveSetS, arrTraversedSetT, arrFreeSet,
                                 pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                                 pnTotalS, pnTotalT, pnTotalFree);
            }
        }
    }
}

void TriggerExpansion(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                      t_arrCoord arrActiveSetS[], t_arrCoord arrTraversedSetT[], t_arrCoord arrFreeSet[],
                      int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                      int *pnTotalS, int *pnTotalT, int *pnTotalFree)
{
    t_arrCoord arrUp    = {arrTargetPos[0] - 1, arrTargetPos[1]};
    t_arrCoord arrDown  = {arrTargetPos[0] + 1, arrTargetPos[1]};
    t_arrCoord arrLeft  = {arrTargetPos[0], arrTargetPos[1] - 1};
    t_arrCoord arrRight = {arrTargetPos[0], arrTargetPos[1] + 1};

    ProcessRemoval(arrTargetPos, arrRedSet, arrBlueSet,
                   arrActiveSetS, arrTraversedSetT, arrFreeSet,
                   pbIsRedTurn, pnTotalRed, pnTotalBlue,
                   pnTotalS, pnTotalT, pnTotalFree);

    if((*pbIsRedTurn))
    {
        ExecuteReplacement(arrUp, arrRedSet, arrBlueSet,
                           arrActiveSetS, arrTraversedSetT, arrFreeSet,
                           pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                           pnTotalS, pnTotalT, pnTotalFree);
    }
    else
    {
        ExecuteReplacement(arrDown, arrRedSet, arrBlueSet,
                           arrActiveSetS, arrTraversedSetT, arrFreeSet,
                           pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                           pnTotalS, pnTotalT, pnTotalFree);
    }

    ExecuteReplacement(arrLeft, arrRedSet, arrBlueSet,
                       arrActiveSetS, arrTraversedSetT, arrFreeSet,
                       pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                       pnTotalS, pnTotalT, pnTotalFree);

    ExecuteReplacement(arrRight, arrRedSet, arrBlueSet,
                       arrActiveSetS, arrTraversedSetT, arrFreeSet,
                       pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                       pnTotalS, pnTotalT, pnTotalFree);
}

void UpdateGameState(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                     t_arrCoord arrActiveSetS[], t_arrCoord arrTraversedSetT[], t_arrCoord arrFreeSet[],
                     int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                     int *pnTotalS, int *pnTotalT, int *pnTotalFree, int *pbIsGoodMove)
{
    int iIndex,
        iEmptyIndex;
    t_arrCoord arrEmpty = {-1, -1};

    *pbIsGoodMove = 0;

    iIndex = SearchCoordinateIndex(arrActiveSetS, arrTargetPos, 9);
    if(iIndex < 0)
    {
        iEmptyIndex = SearchCoordinateIndex(arrActiveSetS, arrEmpty, 9);
        if(iEmptyIndex >= 0)
            AddCoordinate(arrActiveSetS, arrTargetPos, iEmptyIndex, pnTotalS);

        *pbIsGoodMove = 1;
    }
    else if(!(*pbIsGoodMove) && iIndex >= 0)
    {
        iIndex = SearchCoordinateIndex(arrTraversedSetT, arrTargetPos, 9);
        if(iIndex < 0)
        {
            iEmptyIndex = SearchCoordinateIndex(arrTraversedSetT, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrTraversedSetT, arrTargetPos, iEmptyIndex, pnTotalT);

            TriggerExpansion(arrTargetPos, arrRedSet, arrBlueSet,
                             arrActiveSetS, arrTraversedSetT, arrFreeSet,
                             pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                             pnTotalS, pnTotalT, pnTotalFree);

            *pbIsGoodMove = 1;
        }
    }
}

void EvaluateGameEnd(int *pnTurnCount, int *pbIsPlacementPhase,
                     int *pnTotalRed, int *pnTotalBlue, int *pnTotalFree, int *pbIsGameOver)
{
    if(*pnTotalFree == 3 || *pnTurnCount >= 20 ||
       (!(*pbIsPlacementPhase) &&
        ((*pnTotalRed > 0 && *pnTotalBlue == 0) ||
         (*pnTotalRed == 0 && *pnTotalBlue > 0))))
    {
        *pbIsGameOver = 1;
    }
}

void PrintDivider(void)
{
    printf("==================================================\n");
}

void PrintHeader(void)
{
    PrintDivider();
    printf("                COLOR CAPTURE GAME                \n");
    printf("                     3 x 3 GRID                    \n");
    PrintDivider();
    printf("  R   = Red piece\n");
    printf("  B   = Blue piece\n");
    printf("  RR  = Red piece with upgraded state\n");
    printf("  BB  = Blue piece with upgraded state\n");
    printf("  -   = Empty cell\n");
    PrintDivider();
    printf("Red moves first.\n");
    printf("First round: each player places one piece.\n");
    printf("After that: players may only choose their own pieces.\n");
    PrintDivider();
}

void PrintStats(int nMove, int nTotalRed, int nTotalBlue, int nTotalFree, int bIsPlacementPhase)
{
    PrintDivider();
    printf("MOVE NUMBER : %d\n", nMove + 1);
    printf("PHASE       : %s\n", bIsPlacementPhase ? "Placement Phase" : "Battle Phase");
    printf("RED PIECES  : %d\n", nTotalRed);
    printf("BLUE PIECES : %d\n", nTotalBlue);
    printf("FREE CELLS  : %d\n", nTotalFree);
    PrintDivider();
}

void RenderBoard(t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[], t_arrCoord arrActiveSetS[])
{
    int iRow, iCol;
    t_arrCoord arrTempCoord;

    printf("\n");
    printf("           COLUMN\n");
    printf("         1    2    3\n");
    printf("       +----+----+----+\n");

    for(iRow = 0; iRow < 3; iRow++)
    {
        printf("ROW %d  |", iRow + 1);

        for(iCol = 0; iCol < 3; iCol++)
        {
            arrTempCoord[0] = iRow;
            arrTempCoord[1] = iCol;

            if(SearchCoordinateIndex(arrRedSet, arrTempCoord, 9) >= 0)
            {
                if(SearchCoordinateIndex(arrActiveSetS, arrTempCoord, 9) >= 0)
                    printf(" RR |");
                else
                    printf(" R  |");
            }
            else if(SearchCoordinateIndex(arrBlueSet, arrTempCoord, 9) >= 0)
            {
                if(SearchCoordinateIndex(arrActiveSetS, arrTempCoord, 9) >= 0)
                    printf(" BB |");
                else
                    printf(" B  |");
            }
            else
            {
                printf(" -  |");
            }
        }

        printf("\n");
        printf("       +----+----+----+\n");
    }

    printf("\n");
}

void DisplayTurnPrompt(int bIsRedTurn)
{
    PrintDivider();
    if(bIsRedTurn)
        printf("CURRENT PLAYER : RED\n");
    else
        printf("CURRENT PLAYER : BLUE\n");

    printf("Enter your chosen coordinate.\n");
    printf("Row    (1-3): ");
}

void ProcessPlayerTurn(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                       t_arrCoord arrActiveSetS[], t_arrCoord arrTraversedSetT[], t_arrCoord arrFreeSet[],
                       int *pnTurnCount, int *pbIsRedTurn, int *pbIsFound,
                       int *pnTotalRed, int *pnTotalBlue, int *pnTotalS,
                       int *pnTotalT, int *pnTotalFree, int *pbIsGoodMove,
                       int *pbIsGameOver, int *pbIsPlacementPhase)
{
    int iIndexRed,
        iIndexBlue,
        iEmptyIndex;
    t_arrCoord arrEmpty = {-1, -1};

    if(arrTargetPos[0] < 0 || arrTargetPos[0] > 2 ||
       arrTargetPos[1] < 0 || arrTargetPos[1] > 2)
    {
        printf("\n[!] Invalid input. Please enter only values from 1 to 3.\n");
        *pbIsGoodMove = 0;
    }
    else
    {
        iIndexRed = SearchCoordinateIndex(arrRedSet, arrTargetPos, 9);
        iIndexBlue = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);

        if(!(*pbIsGameOver))
        {
            if((*pbIsPlacementPhase))
            {
                if((*pbIsRedTurn))
                {
                    iEmptyIndex = SearchCoordinateIndex(arrRedSet, arrEmpty, 9);
                    if(iEmptyIndex >= 0)
                        AddCoordinate(arrRedSet, arrTargetPos, iEmptyIndex, pnTotalRed);
                }
                else
                {
                    iEmptyIndex = SearchCoordinateIndex(arrBlueSet, arrEmpty, 9);
                    if(iEmptyIndex >= 0)
                        AddCoordinate(arrBlueSet, arrTargetPos, iEmptyIndex, pnTotalBlue);
                }

                iIndexRed = SearchCoordinateIndex(arrFreeSet, arrTargetPos, 9);
                if(iIndexRed >= 0)
                    ClearCoordinate(arrFreeSet, iIndexRed, pnTotalFree);

                iIndexRed = SearchCoordinateIndex(arrActiveSetS, arrTargetPos, 9);
                if(iIndexRed < 0)
                {
                    iEmptyIndex = SearchCoordinateIndex(arrActiveSetS, arrEmpty, 9);
                    if(iEmptyIndex >= 0)
                        AddCoordinate(arrActiveSetS, arrTargetPos, iEmptyIndex, pnTotalS);
                }

                *pbIsGoodMove = 1;
                printf("\n[OK] Piece placed successfully.\n");
            }
            else
            {
                if(((*pbIsRedTurn) && iIndexRed >= 0) ||
                   ((!(*pbIsRedTurn) && iIndexBlue >= 0)))
                {
                    UpdateGameState(arrTargetPos, arrRedSet, arrBlueSet,
                                    arrActiveSetS, arrTraversedSetT, arrFreeSet,
                                    pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                                    pnTotalS, pnTotalT, pnTotalFree, pbIsGoodMove);

                    printf("\n[OK] Move processed.\n");
                }
                else
                {
                    if(iIndexRed < 0 && iIndexBlue < 0)
                        printf("\n[!] Invalid move. You cannot place a new piece now.\n");
                    else
                        printf("\n[!] Invalid move. That piece belongs to your opponent.\n");

                    *pbIsGoodMove = 0;
                }
            }

            if((*pbIsGoodMove))
            {
                *pbIsGoodMove = 0;
                *pbIsRedTurn = !(*pbIsRedTurn);
                (*pnTurnCount)++;
            }
        }
    }

    if((*pbIsPlacementPhase) && (*pnTotalRed) == 1 && (*pnTotalBlue) == 1)
    {
        *pbIsPlacementPhase = 0;
        printf("\n>>> Placement phase complete. Battle phase begins. <<<\n");
    }
}

void DisplayMatchResult(int *pbIsGameOver, int *pnTotalRed, int *pnTotalBlue)
{
    if(*pbIsGameOver)
    {
        printf("\n");
        PrintDivider();
        printf("                   FINAL RESULT                    \n");
        PrintDivider();
        printf("RED PIECES  : %d\n", *pnTotalRed);
        printf("BLUE PIECES : %d\n", *pnTotalBlue);

        if((*pnTotalRed) > (*pnTotalBlue))
            printf("WINNER      : RED\n");
        else if((*pnTotalRed) < (*pnTotalBlue))
            printf("WINNER      : BLUE\n");
        else
            printf("WINNER      : DRAW\n");

        PrintDivider();
    }
}

int main(void)
{
    t_arrCoord arrRedSet[9],
               arrBlueSet[9],
               arrActiveSetS[9],
               arrTraversedSetT[9],
               arrFreeSet[9],
               arrCurrentPos;

    int nTotalRed,
        nTotalBlue,
        nTotalS,
        nTotalT,
        nTotalFree,
        bIsGoodMove,
        bIsRedTurn,
        bIsPlacementPhase,
        bIsGameOver,
        bIsFound,
        nTurnCount;

    char cChoice;

    do
    {
        nTotalRed = 0;
        nTotalBlue = 0;
        nTotalS = 0;
        nTotalT = 0;
        nTotalFree = 9;
        bIsGoodMove = 0;
        bIsRedTurn = 1;
        bIsPlacementPhase = 1;
        bIsGameOver = 0;
        bIsFound = 0;
        nTurnCount = 0;

        InitializeSet(arrRedSet, 9, 0);
        InitializeSet(arrBlueSet, 9, 0);
        InitializeSet(arrActiveSetS, 9, 0);
        InitializeSet(arrTraversedSetT, 9, 0);
        InitializeSet(arrFreeSet, 9, 1);

        PrintHeader();

        while(!bIsGameOver)
        {
            PrintStats(nTurnCount, nTotalRed, nTotalBlue, nTotalFree, bIsPlacementPhase);
            RenderBoard(arrRedSet, arrBlueSet, arrActiveSetS);

            DisplayTurnPrompt(bIsRedTurn);
            scanf("%d", &arrCurrentPos[0]);
            arrCurrentPos[0]--;

            printf("Column (1-3): ");
            scanf("%d", &arrCurrentPos[1]);
            arrCurrentPos[1]--;

            ProcessPlayerTurn(arrCurrentPos, arrRedSet, arrBlueSet,
                              arrActiveSetS, arrTraversedSetT, arrFreeSet,
                              &nTurnCount, &bIsRedTurn, &bIsFound,
                              &nTotalRed, &nTotalBlue, &nTotalS,
                              &nTotalT, &nTotalFree, &bIsGoodMove,
                              &bIsGameOver, &bIsPlacementPhase);

            EvaluateGameEnd(&nTurnCount, &bIsPlacementPhase,
                            &nTotalRed, &nTotalBlue, &nTotalFree, &bIsGameOver);
        }

        printf("\nFINAL BOARD:\n");
        RenderBoard(arrRedSet, arrBlueSet, arrActiveSetS);
        DisplayMatchResult(&bIsGameOver, &nTotalRed, &nTotalBlue);

        printf("Play again? [Y/N]: ");
        scanf(" %c", &cChoice);
        printf("\n");

    } while(cChoice != 'N' && cChoice != 'n');

    printf("Thank you for playing Color Capture Game.\n");
    return 0;
}
