#include <stdio.h>
#include <string.h>

typedef int coord[2];
typedef int grid[3][3];
typedef char String10[10];

int LinearSearch(coord Array[], coord Key, int *size)
{
	int index,
		res = -1,
		match = 0;
	
	for(index = 0; index < (*size) && !match; index++)
	{
		if(Array[index][0] == Key[0] && Array[index][1] == Key[1])
		{
			res = index;
			match = 1;
		}
	}
	
	return res;
}

void removeLoc(coord pos[], int *index, int *total)
{
	pos[*index][0] = -1; //changed to -1, (0,0) is the first row,col in the cell
	pos[*index][1] = -1;
	(*total)--;
}

void Remove(coord pos, coord R[], coord B[], 
			coord S[], coord T[], int *go,
			int *totalR, int *totalB, int *totalS, int *totalT)
{
	int index;
	
	if((*go))
	{
		//check if pos is in set R and get its index
		index = LinearSearch(R, pos, totalR);
		//empty the element in the index found
		if(index >= 0)
		{
			removeLoc(R, &index, totalR);
		}
	}
	else //replaced else-if statement instead
	{
		//check if pos is in set B and get its index
		index = LinearSearch(B, pos, totalB);
		//empty the element in the index found
		if(index >= 0)
		{
			removeLoc(B, &index, totalB);
		}
	}
	
	////////////////////////////////////////
	//added conditional statements, prevents returning -1 (removeLoc)
	//if set S and T has no coordinates
	//no conditional statements = crash
	index = LinearSearch(S, pos, totalS);
	if(index >= 0){
		removeLoc(S, &index, totalS);
	}
	
	index = LinearSearch(T, pos, totalT);
	if(index >= 0){
		removeLoc(T, &index, totalT);
	}
}

void Expand(coord pos, coord R[], coord B[], 
			coord S[], coord T[], int *go, int *found,
			int *totalR, int *totalB, int *totalS, int *totalT);

void Replace(coord pos, coord R[], coord B[], 
			coord S[], coord T[], int *go, int *found,
			int *totalR, int *totalB, int *totalS, int *totalT)
{
	int index;
	*found = 0;

	if (pos[0] >= 0 && pos[0] <= 2 && pos[1] >= 0 && pos[1] <= 2){
		//check if pos is in set B and get its index
		index = LinearSearch(B, pos, totalB);
		if((*go) && index >= 0)
		{
			removeLoc(B, &index, totalB);
			(*found) = 1;
		}
	
		//check if pos is in set R and get its index
		index = LinearSearch(R, pos, totalR);
		if((*go) && index >= 0)
		{
			(*found) = 1;
		}
		else if((*go) && index < 0)
		{
			//add the current position on the last index
			R[*totalR][0] = pos[0];
			R[*totalR][1] = pos[1];
			//increment the total elements in set R
			(*totalR)++;
		}
	
		////////////////////////////////////////
	
		if(!(*go) && index >= 0)
		{
			removeLoc(R, &index, totalR);
			(*found) = 1;
		}
	
		index = LinearSearch(B, pos, totalB);
		if(!(*go) && index >= 0)
		{
			(*found) = 1;
		}
		else if(!(*go) && index < 0)
		{
			B[*totalB][0] = pos[0];
			B[*totalB][1] = pos[1];
			(*totalB)++;
		}
		////////////////////////////////////////
		index = LinearSearch(S, pos, totalS);
		if((*found) && index < 0)
		{
			S[*totalS][0] = pos[0];
			S[*totalS][1] = pos[1];
			(*totalS)++;
		
			(*found) = 0;
		}
		else if((*found) && index >= 0 && (LinearSearch(T, pos, totalT) < 0)) //fixed the bracket
		{ //used else if, since if found  = 0, it will not execute the if block
			T[*totalT][0] = pos[0];
			T[*totalT][1] = pos[1];
			(*totalT)++;
			Expand(pos, R, B, 
				S, T, go, found,
				totalR, totalB, totalS, totalT);
		}		
	}
}

void Expand(coord pos, coord R[], coord B[], 
			coord S[], coord T[], int *go, int *found,
			int *totalR, int *totalB, int *totalS, int *totalT)
{
	coord u;
		u[0] = (pos[0]) - 1;
		u[1] = pos[1];
		
	coord d;
		d[0] = (pos[0]) + 1;
		d[1] = pos[1];
		
	coord k;
		k[0] = pos[0];
		k[1] = (pos[1]) - 1;
		
	coord r;
		r[0] = pos[0];
		r[1] = (pos[1]) + 1;
		
	Remove(pos, R, B, 
			S, T, go,
			totalR, totalB, totalS, totalT);
			
	if((*go))
	{
		Replace(u, R, B, 
			S, T, go, found,
			totalR, totalB, totalS, totalT);
	}
	else if(!(*go))
	{
		Replace(d, R, B, 
			S, T, go, found,
			totalR, totalB, totalS, totalT);
	}
	
	Replace(k, R, B, 
			S, T, go, found,
			totalR, totalB, totalS, totalT);
	
	Replace(r, R, B, 
			S, T, go, found,
			totalR, totalB, totalS, totalT);	
}

void Update(coord pos, coord R[], coord B[], 
			coord S[], coord T[], int *go, int *found,
			int *totalR, int *totalB, int *totalS, int *totalT, int *good)
{
	int index;
	(*good) = 0;
	index = LinearSearch(S, pos, totalS);
	if(index < 0)
	{
		S[*totalS][0] = pos[0];
		S[*totalS][1] = pos[1];
		(*totalS)++;
		
		(*good) = !(*good); //good = -good
	}
	
	index = LinearSearch(S, pos, totalS);
	if(!(*good) && index >= 0 && (LinearSearch(T, pos, totalT) < 0)) //NOT good, based on specs
	{
		T[*totalT][0] = pos[0];
		T[*totalT][1] = pos[1];
		(*totalT)++;
		
		Expand(pos, R, B, 
			S, T, go, found,
			totalR, totalB, totalS, totalT);

		*good = 1; //move IS valid (if expansion happened)
	}
}

int checkFreeSpaces(coord R[], coord B[], grid F, int *totalR, int *totalB)
{
	int a,
		b,
		res = 0,
		coordIndex;
	
	
	for(a = 0; a < 3; a++) //ROW
	{
		for(b = 0; b < 3; b++) //COLUMN
		{
			F[a][b] = 0;
		}
	}
	
	for(coordIndex = 0; coordIndex < (*totalR); coordIndex++)
	{
		F[R[coordIndex][0]][R[coordIndex][1]] = 1;
	}
	
	for(coordIndex = 0; coordIndex < (*totalB); coordIndex++)
	{
		F[B[coordIndex][0]][B[coordIndex][1]] = 1;
	}
	
	for(a = 0; a < 3; a++)
	{
		for(b = 0; b < 3; b++)
		{
			if(F[a][b] == 0)
				res++;
		}
	}
	
	return res;
}

void checkIfOver(coord R[], coord B[], grid F, int *val, 
			int *start, int *totalR, int *totalB, int *over)
{
	int freeSpace = checkFreeSpaces(R, B, F, totalR, totalB);
	
	if ((freeSpace == 3 || *val >= 20 || !*start) &&
    ((*totalR > 0 && *totalB == 0) || (*totalR == 0 && *totalB > 0))) 
	{
		(*over) = 1;
	}
	
}

void NextPlayerMove(coord pos, coord R[], coord B[], 
			coord S[], coord T[], grid F, int *val, int *go, int *found,
			int *totalR, int *totalB, int *totalS, int *totalT, int *good, 
			int *over, int *start)
{
	int indexR = LinearSearch(R, pos, totalR);
	int indexB = LinearSearch(B, pos, totalB);
	
	checkIfOver(R, B, F, val, 
			start, totalR, totalB, over);
	
	if(!(*over)) //separated *start and *go/-*go
	{
		if((*start))
		{
			if((*go)){
				R[*totalR][0] = pos[0];
				R[*totalR][1] = pos[1];
				(*totalR)++;
				printf("POS IS ADDED TO R\n"); //debug
			}
			else{
				B[*totalB][0] = pos[0];
				B[*totalB][1] = pos[1];
				(*totalB)++;
				printf("POS IS ADDED TO B\n"); //debug
			}
			
			if(LinearSearch(S, pos, totalS) < 0){ //add to S
				S[*totalS][0] = pos[0];
				S[*totalS][1] = pos[1];
				(*totalS)++;
				printf("POS IS ADDED TO S\n"); //debug
			}
			(*good) = 1;
		}
		else if(!(*start)){
			if(((*go) && indexR >= 0) || (!(*go) && indexB >= 0)){//used indexR and indexB for readability
				Update(pos, R, B, 
						S, T, go, found,
						totalR, totalB, totalS, totalT, good);
				(*good) = 1;
				printf("BEING UPDATED\n");
			}
			else{
				(*good) = 0; //move is not valid
			}
		}
		
		if ((*good)){
			(*good) = 0;
			(*go) = !(*go);
			(*val)++;
		}
	}
	
	if ((*start) && (*totalR) == 1 && (*totalB) == 1)
			(*start) = 0;
}

void GameOver(coord R[], coord B[], int *over, int *totalR, int *totalB)
{
	String10 result[3] = {"R wins", "B wins", "Draw"};
	
	if((*over) && (*totalR) > (*totalB))
		printf("%s", result[0]);
	else if((*over) && (*totalR) < (*totalB))
		printf("%s", result[1]);
	else if((*over) && (*totalR) == (*totalB))
		printf("%s", result[2]);
}

void printGrid(coord R[], coord B[], int *totalR, int *totalB)
{
	int a,
		b;
		
	coord temp;
	
	for(a = 0; a < 3; a++)
	{
		for(b = 0; b < 3; b++)
		{
			temp[0] = a;
			temp[1] = b;
			
			if(LinearSearch(R, temp, totalR) >= 0)
			{
				printf("R");
			}
			else if(LinearSearch(B, temp, totalB) >= 0)
			{
				printf("B");
			}
			else
				printf("-");
			if(b == 2)
				printf("\n");
		}
	}
}

int main()
{	
	coord R[9] = {},
		B[9] = {},
		S[9] = {},
		T[9] = {},
		pos;
	
	grid F;
	
	int ctr,
		ctr2;
	for(ctr = 0; ctr < 3; ctr++)
	{
		for(ctr2 = 0; ctr2 < 3; ctr2++)
		{
			F[ctr][ctr2] = 0;
		}
	}
	
	int totalR = 0,
		totalB = 0,
		totalS = 0,
		totalT = 0,
		good = 0,
		go = 1,
		start = 1,
		over = 0,
		found = 0,
		val = 0;
	
	while(!over)
	{
		printf("\n");
		printGrid(R, B, &totalR, &totalB);
		printf("\n");
		
		if(go)
		{
			printf("Red's turn: Input Coordinates\n");
			printf("A: \n");
			scanf("%d", &pos[0]);
			pos[0]--;
			printf("B: \n");
			scanf("%d", &pos[1]);
			pos[1]--;
		}
		else if(!go)
		{
			printf("Blue's turn: Input Coordinates\n");
			printf("A(1-3): \n");
			scanf("%d", &pos[0]);
			pos[0]--;
			printf("B(1-3: \n");
			scanf("%d", &pos[1]);
			pos[1]--;
		}
		
		NextPlayerMove(pos, R, B, 
			S, T, F, &val, &go, &found,
			&totalR, &totalB, &totalS, &totalT, &good, 
			&over, &start);
	}
	GameOver(R, B, &over, &totalR, &totalB);
	
	
	return 0;
}



