#include <stdio.h>
#include <string.h>

// coordinate = [row, col]
typedef int t_arrCoord[2];
// string type for final result text
typedef char t_szString10[11];

// searches for a coordinate in a set
// returns its index if found, otherwise -1
int SearchCoordinateIndex(t_arrCoord arrHaystack[], t_arrCoord arrKey, int nSize)
{
    int iIndex,
        iResult = -1,
        bIsMatch = 0;

    for(iIndex = 0; iIndex < nSize && !bIsMatch; iIndex++)
    {
        if(arrHaystack[iIndex][0] == arrKey[0] &&
           arrHaystack[iIndex][1] == arrKey[1])
        {
            iResult = iIndex;
            bIsMatch = 1;
        }
    }

    return iResult;
}

// initializes a set
// free set gets all valid board coordinates
// other sets get (-1, -1)
void InitializeSet(t_arrCoord arrSet[], int nSize, int bIsFreeSet)
{
    int iIndex;

    for(iIndex = 0; iIndex < nSize; iIndex++)
    {
        if(bIsFreeSet)
        {
            arrSet[iIndex][0] = iIndex / 3;
            arrSet[iIndex][1] = iIndex % 3;
        }
        else
        {
            arrSet[iIndex][0] = -1;
            arrSet[iIndex][1] = -1;
        }
    }
}

// clears one coordinate from a set
void ClearCoordinate(t_arrCoord arrPositions[], int iIndex, int *pnTotal)
{
    arrPositions[iIndex][0] = -1;
    arrPositions[iIndex][1] = -1;
    (*pnTotal)--;
}

// adds one coordinate to a set
void AddCoordinate(t_arrCoord arrPositions[], t_arrCoord arrPos, int iIndex, int *pnTotal)
{
    arrPositions[iIndex][0] = arrPos[0];
    arrPositions[iIndex][1] = arrPos[1];
    (*pnTotal)++;
}

// prints a divider for the UI
void PrintDivider(void)
{
    printf("==================================================\n");
}

// prints the game title and guide
void PrintHeader(void)
{
    PrintDivider();
    printf("                COLOR CAPTURE GAME                \n");
    printf("                     3 x 3 GRID                    \n");
    PrintDivider();
    printf("  R   = Red piece\n");
    printf("  B   = Blue piece\n");
    printf("  RR  = Red piece in set S\n");
    printf("  BB  = Blue piece in set S\n");
    printf("  -   = Empty cell\n");
    PrintDivider();
    printf("Red moves first.\n");
    printf("Start phase: each player places one piece.\n");
    printf("Battle phase: players may only choose their own piece.\n");
    PrintDivider();
}

// prints current move stats
void PrintStats(int nMove, int nTotalRed, int nTotalBlue, int nTotalFree, int bIsStart)
{
    PrintDivider();
    printf("MOVE NUMBER : %d\n", nMove + 1);
    printf("PHASE       : %s\n", bIsStart ? "Start Phase" : "Battle Phase");
    printf("RED PIECES  : %d\n", nTotalRed);
    printf("BLUE PIECES : %d\n", nTotalBlue);
    printf("FREE CELLS  : %d\n", nTotalFree);
    PrintDivider();
}

// draws the current board
void RenderBoard(t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[], t_arrCoord arrSetS[])
{
    int iRow,
        iCol;
    t_arrCoord arrTemp;

    printf("\n");
    printf("           COLUMN\n");
    printf("         1    2    3\n");
    printf("       +----+----+----+\n");

    for(iRow = 0; iRow < 3; iRow++)
    {
        printf("ROW %d  |", iRow + 1);

        for(iCol = 0; iCol < 3; iCol++)
        {
            arrTemp[0] = iRow;
            arrTemp[1] = iCol;

            if(SearchCoordinateIndex(arrRedSet, arrTemp, 9) >= 0)
            {
                if(SearchCoordinateIndex(arrSetS, arrTemp, 9) >= 0)
                    printf(" RR |");
                else
                    printf(" R  |");
            }
            else if(SearchCoordinateIndex(arrBlueSet, arrTemp, 9) >= 0)
            {
                if(SearchCoordinateIndex(arrSetS, arrTemp, 9) >= 0)
                    printf(" BB |");
                else
                    printf(" B  |");
            }
            else
            {
                printf(" -  |");
            }
        }

        printf("\n");
        printf("       +----+----+----+\n");
    }

    printf("\n");
}

// shows whose turn it is and asks for input
void DisplayTurnPrompt(int bIsRedTurn)
{
    PrintDivider();
    printf("CURRENT PLAYER : %s\n", bIsRedTurn ? "RED" : "BLUE");
    printf("Enter your chosen coordinate.\n");
    printf("Row    (1-3): ");
}

// removes a position from the needed sets
void ProcessRemoval(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                    t_arrCoord arrSetS[], t_arrCoord arrSetT[], t_arrCoord arrSetF[],
                    int *pbIsRedTurn, int *pnTotalRed, int *pnTotalBlue,
                    int *pnTotalS, int *pnTotalT, int *pnTotalF)
{
    int iIndex,
        iEmptyIndex;
    t_arrCoord arrEmpty = {-1, -1};

    // remove from current player's main set
    if((*pbIsRedTurn))
    {
        iIndex = SearchCoordinateIndex(arrRedSet, arrTargetPos, 9);
        if(iIndex >= 0)
        {
            ClearCoordinate(arrRedSet, iIndex, pnTotalRed);

            iEmptyIndex = SearchCoordinateIndex(arrSetF, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrSetF, arrTargetPos, iEmptyIndex, pnTotalF);
        }
    }
    else
    {
        iIndex = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);
        if(iIndex >= 0)
        {
            ClearCoordinate(arrBlueSet, iIndex, pnTotalBlue);

            iEmptyIndex = SearchCoordinateIndex(arrSetF, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrSetF, arrTargetPos, iEmptyIndex, pnTotalF);
        }
    }

    // remove from set S if present
    iIndex = SearchCoordinateIndex(arrSetS, arrTargetPos, 9);
    if(iIndex >= 0)
        ClearCoordinate(arrSetS, iIndex, pnTotalS);

    // remove from set T if present
    iIndex = SearchCoordinateIndex(arrSetT, arrTargetPos, 9);
    if(iIndex >= 0)
        ClearCoordinate(arrSetT, iIndex, pnTotalT);
}

// function prototype because ExecuteReplacement uses this before full definition
void TriggerExpansion(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                      t_arrCoord arrSetS[], t_arrCoord arrSetT[], t_arrCoord arrSetF[],
                      int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                      int *pnTotalS, int *pnTotalT, int *pnTotalF);

// handles replacing or upgrading neighboring cells during expansion
void ExecuteReplacement(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                        t_arrCoord arrSetS[], t_arrCoord arrSetT[], t_arrCoord arrSetF[],
                        int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                        int *pnTotalS, int *pnTotalT, int *pnTotalF)
{
    int iIndex,
        iEmptyIndex;
    t_arrCoord arrEmpty = {-1, -1};

    // assume not found at first
    *pbIsFound = 0;

    // only process coordinates inside the board
    if(arrTargetPos[0] >= 0 && arrTargetPos[0] <= 2 &&
       arrTargetPos[1] >= 0 && arrTargetPos[1] <= 2)
    {
        // if red's turn, first check if blue owns the cell
        iIndex = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);
        if((*pbIsRedTurn) && iIndex >= 0)
        {
            ClearCoordinate(arrBlueSet, iIndex, pnTotalBlue);

            iEmptyIndex = SearchCoordinateIndex(arrSetF, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrSetF, arrTargetPos, iEmptyIndex, pnTotalF);

            *pbIsFound = 1;
        }

        // check if red already owns the cell
        iIndex = SearchCoordinateIndex(arrRedSet, arrTargetPos, 9);
        if((*pbIsRedTurn) && iIndex >= 0)
        {
            *pbIsFound = 1;
        }
        else if((*pbIsRedTurn) && iIndex < 0)
        {
            // if red does not own it yet, add it to red
            iEmptyIndex = SearchCoordinateIndex(arrRedSet, arrEmpty, 9);
            if(iEmptyIndex >= 0)
            {
                AddCoordinate(arrRedSet, arrTargetPos, iEmptyIndex, pnTotalRed);

                iIndex = SearchCoordinateIndex(arrSetF, arrTargetPos, 9);
                if(iIndex >= 0)
                    ClearCoordinate(arrSetF, iIndex, pnTotalF);
            }
        }

        // if blue's turn, check red's ownership first
        if(!(*pbIsRedTurn))
        {
            iIndex = SearchCoordinateIndex(arrRedSet, arrTargetPos, 9);
            if(iIndex >= 0)
            {
                ClearCoordinate(arrRedSet, iIndex, pnTotalRed);

                iEmptyIndex = SearchCoordinateIndex(arrSetF, arrEmpty, 9);
                if(iEmptyIndex >= 0)
                    AddCoordinate(arrSetF, arrTargetPos, iEmptyIndex, pnTotalF);

                *pbIsFound = 1;
            }

            // then check if blue already owns it
            iIndex = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);
            if(iIndex >= 0)
            {
                *pbIsFound = 1;
            }
            else
            {
                // if not, add it to blue
                iEmptyIndex = SearchCoordinateIndex(arrBlueSet, arrEmpty, 9);
                if(iEmptyIndex >= 0)
                {
                    AddCoordinate(arrBlueSet, arrTargetPos, iEmptyIndex, pnTotalBlue);

                    iIndex = SearchCoordinateIndex(arrSetF, arrTargetPos, 9);
                    if(iIndex >= 0)
                        ClearCoordinate(arrSetF, iIndex, pnTotalF);
                }
            }
        }

        // if the cell was involved, check if it should enter S
        iIndex = SearchCoordinateIndex(arrSetS, arrTargetPos, 9);
        if((*pbIsFound) && iIndex < 0)
        {
            iEmptyIndex = SearchCoordinateIndex(arrSetS, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrSetS, arrTargetPos, iEmptyIndex, pnTotalS);

            *pbIsFound = 0;
        }
        else if((*pbIsFound) && iIndex >= 0)
        {
            // if already in S, check if it should enter T and expand
            iIndex = SearchCoordinateIndex(arrSetT, arrTargetPos, 9);
            if(iIndex < 0)
            {
                iEmptyIndex = SearchCoordinateIndex(arrSetT, arrEmpty, 9);
                if(iEmptyIndex >= 0)
                    AddCoordinate(arrSetT, arrTargetPos, iEmptyIndex, pnTotalT);

                TriggerExpansion(arrTargetPos, arrRedSet, arrBlueSet,
                                 arrSetS, arrSetT, arrSetF,
                                 pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                                 pnTotalS, pnTotalT, pnTotalF);
            }
        }
    }
}

// expands a position to neighboring cells
void TriggerExpansion(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                      t_arrCoord arrSetS[], t_arrCoord arrSetT[], t_arrCoord arrSetF[],
                      int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                      int *pnTotalS, int *pnTotalT, int *pnTotalF)
{
    // neighboring coordinates
    t_arrCoord arrUp = {arrTargetPos[0] - 1, arrTargetPos[1]};
    t_arrCoord arrDown = {arrTargetPos[0] + 1, arrTargetPos[1]};
    t_arrCoord arrLeft = {arrTargetPos[0], arrTargetPos[1] - 1};
    t_arrCoord arrRight = {arrTargetPos[0], arrTargetPos[1] + 1};

    // first remove the exploding piece
    ProcessRemoval(arrTargetPos, arrRedSet, arrBlueSet,
                   arrSetS, arrSetT, arrSetF,
                   pbIsRedTurn, pnTotalRed, pnTotalBlue,
                   pnTotalS, pnTotalT, pnTotalF);

    // vertical direction depends on whose turn it is
    if((*pbIsRedTurn))
    {
        ExecuteReplacement(arrUp, arrRedSet, arrBlueSet,
                           arrSetS, arrSetT, arrSetF,
                           pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                           pnTotalS, pnTotalT, pnTotalF);
    }
    else
    {
        ExecuteReplacement(arrDown, arrRedSet, arrBlueSet,
                           arrSetS, arrSetT, arrSetF,
                           pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                           pnTotalS, pnTotalT, pnTotalF);
    }

    // always affect left and right
    ExecuteReplacement(arrLeft, arrRedSet, arrBlueSet,
                       arrSetS, arrSetT, arrSetF,
                       pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                       pnTotalS, pnTotalT, pnTotalF);

    ExecuteReplacement(arrRight, arrRedSet, arrBlueSet,
                       arrSetS, arrSetT, arrSetF,
                       pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                       pnTotalS, pnTotalT, pnTotalF);
}

// updates a selected piece during battle phase
void UpdateGameState(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                     t_arrCoord arrSetS[], t_arrCoord arrSetT[], t_arrCoord arrSetF[],
                     int *pbIsRedTurn, int *pbIsFound, int *pnTotalRed, int *pnTotalBlue,
                     int *pnTotalS, int *pnTotalT, int *pnTotalF, int *pbIsGoodMove)
{
    int iIndex,
        iEmptyIndex;
    t_arrCoord arrEmpty = {-1, -1};

    // start with move marked invalid
    *pbIsGoodMove = 0;

    // if not yet in S, add it there
    iIndex = SearchCoordinateIndex(arrSetS, arrTargetPos, 9);
    if(iIndex < 0)
    {
        iEmptyIndex = SearchCoordinateIndex(arrSetS, arrEmpty, 9);
        if(iEmptyIndex >= 0)
            AddCoordinate(arrSetS, arrTargetPos, iEmptyIndex, pnTotalS);

        *pbIsGoodMove = !(*pbIsGoodMove);
    }
    else if(!(*pbIsGoodMove) && iIndex >= 0)
    {
        // if already in S, check if it should go to T and expand
        iIndex = SearchCoordinateIndex(arrSetT, arrTargetPos, 9);
        if(iIndex < 0)
        {
            iEmptyIndex = SearchCoordinateIndex(arrSetT, arrEmpty, 9);
            if(iEmptyIndex >= 0)
                AddCoordinate(arrSetT, arrTargetPos, iEmptyIndex, pnTotalT);

            TriggerExpansion(arrTargetPos, arrRedSet, arrBlueSet,
                             arrSetS, arrSetT, arrSetF,
                             pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                             pnTotalS, pnTotalT, pnTotalF);

            *pbIsGoodMove = 1;
        }
    }
}

// checks if any game-over condition is met
void EvaluateGameEnd(int *pnTurnCount, int *pbIsStart,
                     int *pnTotalRed, int *pnTotalBlue, int *pnTotalF, int *pbIsGameOver)
{
    if(*pnTotalF == 3 || *pnTurnCount >= 20 ||
       (!(*pbIsStart) &&
       (((*pnTotalRed > 0) && (*pnTotalBlue == 0)) ||
        ((*pnTotalRed == 0) && (*pnTotalBlue > 0)))))
    {
        *pbIsGameOver = 1;
    }
}

// handles one player's move
void ProcessPlayerTurn(t_arrCoord arrTargetPos, t_arrCoord arrRedSet[], t_arrCoord arrBlueSet[],
                       t_arrCoord arrSetS[], t_arrCoord arrSetT[], t_arrCoord arrSetF[],
                       int *pnTurnCount, int *pbIsRedTurn, int *pbIsFound,
                       int *pnTotalRed, int *pnTotalBlue, int *pnTotalS,
                       int *pnTotalT, int *pnTotalF, int *pbIsGoodMove,
                       int *pbIsGameOver, int *pbIsStart)
{
    int iIndexRed,
        iIndexBlue,
        iEmptyIndex;
    t_arrCoord arrEmpty = {-1, -1};

    // reject out-of-bounds input
    if(arrTargetPos[0] < 0 || arrTargetPos[0] > 2 ||
       arrTargetPos[1] < 0 || arrTargetPos[1] > 2)
    {
        printf("\n[!] Invalid Input: only enter values from 1 to 3.\n");
        *pbIsGoodMove = 0;
    }
    else
    {
        iIndexRed = SearchCoordinateIndex(arrRedSet, arrTargetPos, 9);
        iIndexBlue = SearchCoordinateIndex(arrBlueSet, arrTargetPos, 9);

        if(!(*pbIsGameOver))
        {
            // start phase: place one piece each
            if((*pbIsStart))
            {
                if((*pbIsRedTurn))
                {
                    iEmptyIndex = SearchCoordinateIndex(arrRedSet, arrEmpty, 9);
                    if(iEmptyIndex >= 0)
                        AddCoordinate(arrRedSet, arrTargetPos, iEmptyIndex, pnTotalRed);
                }
                else
                {
                    iEmptyIndex = SearchCoordinateIndex(arrBlueSet, arrEmpty, 9);
                    if(iEmptyIndex >= 0)
                        AddCoordinate(arrBlueSet, arrTargetPos, iEmptyIndex, pnTotalBlue);
                }

                // add placed piece to S if not there yet
                if(SearchCoordinateIndex(arrSetS, arrTargetPos, 9) < 0)
                {
                    iEmptyIndex = SearchCoordinateIndex(arrSetS, arrEmpty, 9);
                    if(iEmptyIndex >= 0)
                        AddCoordinate(arrSetS, arrTargetPos, iEmptyIndex, pnTotalS);
                }

                // remove from free set
                iIndexRed = SearchCoordinateIndex(arrSetF, arrTargetPos, 9);
                if(iIndexRed >= 0)
                    ClearCoordinate(arrSetF, iIndexRed, pnTotalF);

                *pbIsGoodMove = 1;
                printf("\n[OK] Piece placed successfully.\n");
            }
            else
            {
                // battle phase: player must choose own piece
                if(((*pbIsRedTurn) && iIndexRed >= 0) ||
                   ((!(*pbIsRedTurn)) && iIndexBlue >= 0))
                {
                    UpdateGameState(arrTargetPos, arrRedSet, arrBlueSet,
                                    arrSetS, arrSetT, arrSetF,
                                    pbIsRedTurn, pbIsFound, pnTotalRed, pnTotalBlue,
                                    pnTotalS, pnTotalT, pnTotalF, pbIsGoodMove);

                    *pbIsGoodMove = 1;
                    printf("\n[OK] Move processed.\n");
                }
                else
                {
                    if(iIndexRed < 0 && iIndexBlue < 0)
                        printf("\n[!] Invalid Move! You cannot add new pieces!\n");
                    else
                        printf("\n[!] Invalid Move: It already belongs to your opponent!\n");

                    *pbIsGoodMove = 0;
                }
            }

            // if move was valid, switch turn and increase move count
            if((*pbIsGoodMove))
            {
                *pbIsGoodMove = !(*pbIsGoodMove);
                *pbIsRedTurn = !(*pbIsRedTurn);
                (*pnTurnCount)++;
            }
        }
    }

    // once both players have placed one piece, start phase ends
    if((*pbIsStart) && (*pnTotalRed) == 1 && (*pnTotalBlue) == 1)
    {
        *pbIsStart = 0;
        printf("\n>>> Start phase complete. Battle phase begins. <<<\n");
    }
}

// prints the final result
void DisplayMatchResult(int *pbIsGameOver, int *pnTotalRed, int *pnTotalBlue)
{
    t_szString10 arrResult[3] = {"R wins", "B wins", "draw"};

    if(*pbIsGameOver)
    {
        printf("\n");
        PrintDivider();
        printf("                   FINAL RESULT                    \n");
        PrintDivider();
        printf("RED PIECES  : %d\n", *pnTotalRed);
        printf("BLUE PIECES : %d\n", *pnTotalBlue);

        if((*pnTotalRed) > (*pnTotalBlue))
            printf("RESULT      : %s\n", arrResult[0]);
        else if((*pnTotalRed) < (*pnTotalBlue))
            printf("RESULT      : %s\n", arrResult[1]);
        else
            printf("RESULT      : %s\n", arrResult[2]);

        PrintDivider();
    }
}

// main driver of the game
int main(void)
{
    t_arrCoord arrRedSet[9],
               arrBlueSet[9],
               arrSetS[9],
               arrSetT[9],
               arrSetF[9],
               arrCurrentPos;

    int nTotalRed,
        nTotalBlue,
        nTotalS,
        nTotalT,
        nTotalF,
        bIsGoodMove,
        bIsRedTurn,
        bIsStart,
        bIsGameOver,
        bIsFound,
        nTurnCount;

    char cChoice;

    do
    {
        // reset game values
        nTotalRed = 0;
        nTotalBlue = 0;
        nTotalS = 0;
        nTotalT = 0;
        nTotalF = 9;
        bIsGoodMove = 0;
        bIsRedTurn = 1;
        bIsStart = 1;
        bIsGameOver = 0;
        bIsFound = 0;
        nTurnCount = 0;

        // initialize all sets
        InitializeSet(arrRedSet, 9, 0);
        InitializeSet(arrBlueSet, 9, 0);
        InitializeSet(arrSetS, 9, 0);
        InitializeSet(arrSetT, 9, 0);
        InitializeSet(arrSetF, 9, 1);

        PrintHeader();

        // main game loop
        while(!bIsGameOver)
        {
            PrintStats(nTurnCount, nTotalRed, nTotalBlue, nTotalF, bIsStart);
            RenderBoard(arrRedSet, arrBlueSet, arrSetS);

            DisplayTurnPrompt(bIsRedTurn);
            scanf("%d", &arrCurrentPos[0]);
            arrCurrentPos[0]--;

            printf("Column (1-3): ");
            scanf("%d", &arrCurrentPos[1]);
            arrCurrentPos[1]--;

            ProcessPlayerTurn(arrCurrentPos, arrRedSet, arrBlueSet,
                              arrSetS, arrSetT, arrSetF,
                              &nTurnCount, &bIsRedTurn, &bIsFound,
                              &nTotalRed, &nTotalBlue, &nTotalS,
                              &nTotalT, &nTotalF, &bIsGoodMove,
                              &bIsGameOver, &bIsStart);

            EvaluateGameEnd(&nTurnCount, &bIsStart,
                            &nTotalRed, &nTotalBlue, &nTotalF, &bIsGameOver);
        }

        // show final board and result
        printf("\nFINAL BOARD:\n");
        RenderBoard(arrRedSet, arrBlueSet, arrSetS);
        DisplayMatchResult(&bIsGameOver, &nTotalRed, &nTotalBlue);

        // ask to play again2
        printf("Play again? [Y/N]: ");
        scanf(" %c", &cChoice);
        printf("\n");

    } while(cChoice != 'N' && cChoice != 'n');

    printf("Thank you for playing Color Capture Game.\n");
    return 0;
}
